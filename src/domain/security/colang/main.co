define user ask offensive question
  "how to hurt"
  "bagaimana cara menyakiti"
  "how to harm"
  "bagaimana cara merugikan"
  "make a weapon"
  "Cara membuat senjata"
  "buatlah bom"
  "attack someone"
  "serang seseorang"
  "bunuh seseorang"
  "cara merugikan negara atau seseorang"
  "physical violence"
  "suicide"
  "bunuh diri"
  "self-harm"

define flow check harmful input
  user express harmful intent
  bot refuse harmful input

define flow check offensive questions
  user ask offensive question
  bot refuse harmful input

define bot refuse harmful input
  "I'm sorry, I cannot assist with that request. I am designed to be a helpful assistant for document analysis and follow strict safety guidelines regarding harmful, toxic, or inappropriate content."

define flow check harmful output
  bot respond
  $is_harmful = execute check_output_for_harm(output=$bot_message)
  if $is_harmful
    bot refuse harmful output

define bot refuse harmful output
  "I'm sorry, I can't provide that information or generate that kind of response."
